{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://githive.dev/spec/schemas/notify.schema.json",
  "title": "notify.* イベントの data スキーマ群",
  "description": "docs/features/notify.md の「イベント定義」表に従う。",
  "$defs": {
    "ulid": {
      "type": "string",
      "pattern": "^[0-9a-hjkmnp-tv-z]{26}$"
    },
    "target": {
      "type": "string",
      "description": "user:<name> / group:<name> / all のいずれか。",
      "pattern": "^(user:[^\\s@]+@[^\\s]+|group:[a-z0-9][a-z0-9-]{1,38}|all)$"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high"
      ]
    },
    "notify.post": {
      "type": "object",
      "description": "当月の jsonl に追記する。",
      "properties": {
        "targets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/target"
          },
          "minItems": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string"
        },
        "source": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string"
            },
            "id": {
              "$ref": "#/$defs/ulid"
            }
          },
          "required": [
            "kind",
            "id"
          ],
          "additionalProperties": true
        },
        "priority": {
          "$ref": "#/$defs/priority"
        }
      },
      "required": [
        "targets",
        "title"
      ],
      "additionalProperties": true
    },
    "notify.ack": {
      "type": "object",
      "description": "acks.json の該当エントリに actor を追加する。",
      "properties": {
        "ack_of": {
          "$ref": "#/$defs/ulid"
        }
      },
      "required": [
        "ack_of"
      ],
      "additionalProperties": true
    },
    "notify.checkpoint": {
      "type": "object",
      "description": "読み出し起点。fold はこの kind を常に無視する。",
      "properties": {
        "state": {
          "type": "object"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "hash": {
          "type": "string"
        }
      },
      "required": [
        "state",
        "count",
        "hash"
      ],
      "additionalProperties": true
    }
  }
}
