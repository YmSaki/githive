{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://githive.dev/spec/schemas/issue.schema.json",
  "title": "issue.* イベントの data スキーマ群",
  "description": "docs/features/issue.md の「イベント定義」表に従う。kind ごとに $defs 内の対応するスキーマで data を検証する。",
  "$defs": {
    "ulid": {
      "type": "string",
      "pattern": "^[0-9a-hjkmnp-tv-z]{26}$"
    },
    "username": {
      "type": "string",
      "pattern": "^[^\\s@]+@[^\\s]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "in_progress",
        "resolved",
        "closed",
        "archived"
      ]
    },
    "issue.create": {
      "type": "object",
      "description": "初期状態を設定する。チェーンの最初のイベントに限る。",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assignees": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/username"
          }
        }
      },
      "required": [
        "title"
      ],
      "additionalProperties": true
    },
    "issue.edit": {
      "type": "object",
      "description": "与えられたフィールドを上書きする（LWW）。",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "issue.status": {
      "type": "object",
      "description": "ステータス機械に従い to へ遷移する。from は監査用で fold には使わない。",
      "properties": {
        "from": {
          "$ref": "#/$defs/status"
        },
        "to": {
          "$ref": "#/$defs/status"
        }
      },
      "required": [
        "to"
      ],
      "additionalProperties": true
    },
    "issue.comment": {
      "type": "object",
      "description": "comments に event-id をキーとして追加する。",
      "properties": {
        "body": {
          "type": "string"
        },
        "reply_to": {
          "$ref": "#/$defs/ulid"
        },
        "supersedes": {
          "description": "既存コメントの置換表示（設計判断の節）。省略可。",
          "$ref": "#/$defs/ulid"
        }
      },
      "required": [
        "body"
      ],
      "additionalProperties": true
    },
    "issue.label": {
      "type": "object",
      "description": "ラベル集合に適用する（remove を先に、add を後に）。",
      "properties": {
        "add": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "remove": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "issue.assign": {
      "type": "object",
      "description": "担当者集合に適用する。",
      "properties": {
        "add": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/username"
          }
        },
        "remove": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/username"
          }
        }
      },
      "additionalProperties": true
    },
    "issue.link": {
      "type": "object",
      "description": "links 集合に適用する。rel は task / issue / chat。",
      "properties": {
        "rel": {
          "type": "string",
          "enum": [
            "task",
            "issue",
            "chat"
          ]
        },
        "id": {
          "$ref": "#/$defs/ulid"
        },
        "remove": {
          "type": "boolean"
        }
      },
      "required": [
        "rel",
        "id"
      ],
      "additionalProperties": true
    },
    "issue.checkpoint": {
      "type": "object",
      "description": "読み出し起点。fold はこの kind を常に無視する（実体化結果には影響しない）。",
      "properties": {
        "state": {
          "type": "object"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "hash": {
          "type": "string"
        }
      },
      "required": [
        "state",
        "count",
        "hash"
      ],
      "additionalProperties": true
    }
  }
}
