{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://githive.dev/spec/schemas/task.schema.json",
  "title": "task.* イベントの data スキーマ群",
  "description": "docs/features/task.md の「イベント定義」表に従う。",
  "$defs": {
    "ulid": {
      "type": "string",
      "pattern": "^[0-9a-hjkmnp-tv-z]{26}$"
    },
    "username": {
      "type": "string",
      "pattern": "^[^\\s@]+@[^\\s]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "todo",
        "doing",
        "review",
        "done",
        "blocked",
        "cancelled"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high"
      ]
    },
    "task.create": {
      "type": "object",
      "description": "初期状態。owner 省略時は actor。",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string"
        },
        "owner": {
          "$ref": "#/$defs/username"
        },
        "due": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "priority": {
          "$ref": "#/$defs/priority"
        }
      },
      "required": [
        "title"
      ],
      "additionalProperties": true
    },
    "task.edit": {
      "type": "object",
      "description": "LWW 上書き。",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string"
        },
        "due": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "priority": {
          "$ref": "#/$defs/priority"
        }
      },
      "additionalProperties": true
    },
    "task.status": {
      "type": "object",
      "description": "遷移し status_history に追記する。note があれば notes にも追加する。",
      "properties": {
        "from": {
          "$ref": "#/$defs/status"
        },
        "to": {
          "$ref": "#/$defs/status"
        },
        "note": {
          "type": "string"
        }
      },
      "required": [
        "to"
      ],
      "additionalProperties": true
    },
    "task.reassign": {
      "type": "object",
      "description": "owner を上書きする（LWW）。",
      "properties": {
        "owner": {
          "$ref": "#/$defs/username"
        }
      },
      "required": [
        "owner"
      ],
      "additionalProperties": true
    },
    "task.note": {
      "type": "object",
      "description": "notes に追記する。",
      "properties": {
        "body": {
          "type": "string"
        }
      },
      "required": [
        "body"
      ],
      "additionalProperties": true
    },
    "task.link": {
      "type": "object",
      "description": "links 集合に適用する。",
      "properties": {
        "rel": {
          "type": "string",
          "enum": [
            "task",
            "issue",
            "chat"
          ]
        },
        "id": {
          "$ref": "#/$defs/ulid"
        },
        "remove": {
          "type": "boolean"
        }
      },
      "required": [
        "rel",
        "id"
      ],
      "additionalProperties": true
    },
    "task.checkpoint": {
      "type": "object",
      "description": "読み出し起点。fold はこの kind を常に無視する。",
      "properties": {
        "state": {
          "type": "object"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "hash": {
          "type": "string"
        }
      },
      "required": [
        "state",
        "count",
        "hash"
      ],
      "additionalProperties": true
    }
  }
}
